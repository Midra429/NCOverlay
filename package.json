{
  "name": "ncoverlay",
  "displayName": "NCOverlay",
  "version": "3.36.4",
  "description": "動画配信サービスの再生画面にニコニコのコメントを表示する拡張機能",
  "author": "Midra <me@midra.me> (https://github.com/Midra429)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "pre": "wxt prepare",
    "dev:chrome": "wxt -b chrome",
    "dev:firefox": "wxt -b firefox",
    "build": "conc bun:build:* --max-processes 1",
    "build:chrome": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox",
    "zip": "conc bun:zip:* --max-processes 1",
    "zip:chrome": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit --skipLibCheck",
    "check": "biome check --write"
  },
  "dependencies": {
    "@heroui/react": "^2.8.10",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@internationalized/date": "^3.12.1",
    "@midra/nco-utils": "^1.2.10",
    "@webext-core/messaging": "^2.3.0",
    "@wxt-dev/is-background": "^1.0.0",
    "@xpadev-net/niconicomments": "^0.2.78",
    "color2k": "^2.0.3",
    "colord": "^2.9.3",
    "deepmerge": "^4.3.1",
    "fast-deep-equal": "^3.1.3",
    "filesize": "^11.0.16",
    "framer-motion": "^12.38.0",
    "hotkeys-js": "^4.0.3",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.9",
    "nanoid-dictionary": "^5.0.0",
    "react": "^19.2.5",
    "react-detectable-overflow": "^0.8.0",
    "react-dom": "^19.2.5",
    "react-hotkeys-hook": "^5.2.4",
    "react-virtuoso": "^4.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/nanoid-dictionary": "^4.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-react": "^1.2.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.10",
    "publish-browser-extension": "^4.0.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "utility-types": "^3.11.0",
    "wxt": "^0.20.25"
  }
}
